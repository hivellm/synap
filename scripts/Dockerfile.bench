# Benchmark-only image: glibc build (avoids the musl toolchain used by the
# release Dockerfile). Not for production. Config baked with RESP3/SynapRPC on
# 0.0.0.0 and persistence disabled for a pure in-memory head-to-head vs Redis.
FROM rust:1-bookworm AS builder
WORKDIR /src
COPY . .
RUN cargo build --release -p synap-server

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /src/target/release/synap-server /usr/local/bin/synap-server
COPY --from=builder /src/target/release/synap_bench /usr/local/bin/synap-bench
COPY config/bench-config.yml /app/config.yml
EXPOSE 6379 15500 15501
CMD ["synap-server", "--config", "/app/config.yml"]
